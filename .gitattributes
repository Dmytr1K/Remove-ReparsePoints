# Auto-detect text files and normalize line endings to LF in the repository
* text=auto eol=lf

# PowerShell files
*.ps1 text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf

# Documentation and plain text
*.md text eol=lf
*.txt text eol=lf

# Configuration and structured data files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Other command-line scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.dll binary
*.exe binary
*.pdb binary
